{
  "name": "calle-ai",
  "version": "1.0.0",
  "description": "Calle AI — an AI-operated local-presence agency (Hermes Buildathon). Multi-agent system that publishes bilingual local-business presence packs.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "deploy": "npm run build && wrangler pages deploy dist --project-name calle-ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgoconnor/calle-ai.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/bgoconnor/calle-ai/issues"
  },
  "homepage": "https://github.com/bgoconnor/calle-ai#readme",
  "dependencies": {
    "convex": "^1.42.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "wrangler": "^4.25.1"
  }
}
